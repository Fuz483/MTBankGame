class Button:
    def __init__(self, x, y, width, height, text, color=ACCENT_COLOR):
        self.rect = pygame.Rect(x, y, width, height)
        self.text = text
        self.color = color
        self.hover_color = tuple(min(255, c + 30) for c in color)
        self.is_hovered = False
        self.click_effect = 0
    
    def draw(self, surface):
        # Click effect animation
        if self.click_effect > 0:
            self.click_effect -= 1
            offset = self.click_effect // 2
        else:
            offset = 0
        
        # Draw button shadow
        shadow_rect = pygame.Rect(self.rect.x + 3, self.rect.y + 3 + offset, 
                                self.rect.width, self.rect.height)
        shadow_surface = pygame.Surface((self.rect.width, self.rect.height), pygame.SRCALPHA)
        pygame.draw.rect(shadow_surface, (0, 0, 0, 100), shadow_surface.get_rect(), border_radius=8)
        surface.blit(shadow_surface, (shadow_rect.x, shadow_rect.y))
        
        # Draw button
        button_rect = pygame.Rect(self.rect.x, self.rect.y + offset, 
                                self.rect.width, self.rect.height)
        color = self.hover_color if self.is_hovered else self.color
        pygame.draw.rect(surface, color, button_rect, border_radius=8)
        pygame.draw.rect(surface, WHITE, button_rect, 2, border_radius=8)
        
        # Draw text with shadow
        text_surface = font_medium.render(self.text, True, WHITE)
        text_shadow = font_medium.render(self.text, True, BLACK)
        text_rect = text_surface.get_rect(center=button_rect.center)
        surface.blit(text_shadow, (text_rect.x + 1, text_rect.y + 1))
        surface.blit(text_surface, text_rect)
    
    def handle_event(self, event):
        if event.type == pygame.MOUSEMOTION:
            self.is_hovered = self.rect.collidepoint(event.pos)
        elif event.type == pygame.MOUSEBUTTONDOWN:
            if self.rect.collidepoint(event.pos):
                self.click_effect = 10  # Animation frames
                return True
        return False

def save_game():
    """Save game state to file"""
    save_data = {
        'grid': grid,
        'experience': experience,
        'last_spawn_time': last_spawn_time,
        'spawns_used_in_period': spawns_used_in_period
    }
    try:
        with open(SAVE_FILE, 'wb') as f:
            pickle.dump(save_data, f)
    except:
        pass

def load_game():
    """Load game state from file"""
    global grid, experience, profile_level, last_spawn_time, spawns_used_in_period
    
    try:
        with open(SAVE_FILE, 'rb') as f:
            save_data = pickle.load(f)
            grid = save_data.get('grid', [[0 for _ in range(GRID_SIZE)] for _ in range(GRID_SIZE)])
            experience = save_data.get('experience', 0)
            last_spawn_time = save_data.get('last_spawn_time', 0)
            spawns_used_in_period = save_data.get('spawns_used_in_period', 0)
            update_profile_level()
    except:
        # Initialize new game if save file doesn't exist
        grid = [[0 for _ in range(GRID_SIZE)] for _ in range(GRID_SIZE)]
        experience = 0
        profile_level = 1
        last_spawn_time = time.time()
        spawns_used_in_period = 0

