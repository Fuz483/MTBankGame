def find_asset_by_token(token):
    """Find image by stable token regardless of exact UUID suffix."""
    pattern = f"*{token}*.png"
    for directory in ASSET_SEARCH_DIRS:
        if not directory.exists():
            continue
        matches = list(directory.glob(pattern))
        if matches:
            # Prefer the newest uploaded file when several matches exist.
            return max(matches, key=lambda path: path.stat().st_mtime)
    return None

def remove_background(image_surface):
    """Remove uniform photo background by comparing to corner color."""
    width, height = image_surface.get_size()
    corners = [
        image_surface.get_at((0, 0)),
        image_surface.get_at((width - 1, 0)),
        image_surface.get_at((0, height - 1)),
        image_surface.get_at((width - 1, height - 1)),
    ]
    bg_r = sum(c.r for c in corners) // 4
    bg_g = sum(c.g for c in corners) // 4
    bg_b = sum(c.b for c in corners) // 4

    threshold = 42
    softness = 32
    processed = image_surface.copy().convert_alpha()

    for py in range(height):
        for px in range(width):
            pixel = processed.get_at((px, py))
            diff = math.sqrt(
                (pixel.r - bg_r) ** 2 +
                (pixel.g - bg_g) ** 2 +
                (pixel.b - bg_b) ** 2
            )
            if diff <= threshold:
                pixel.a = 0
            elif diff <= threshold + softness:
                alpha_ratio = (diff - threshold) / softness
                pixel.a = int(255 * alpha_ratio)
            else:
                pixel.a = 255
            processed.set_at((px, py), pixel)

    return processed

