def can_spawn():
    """Check if player can spawn a new car"""
    try:
        # Always allow spawning if there are empty cells
        for row in range(GRID_SIZE):
            for col in range(GRID_SIZE):
                if grid[row][col] == 0:
                    return True
        return False
    except Exception as e:
        print(f"Error in can_spawn: {e}")
        return False

def spawn_car():
    """Spawn a new car in a random empty cell."""
    try:
        if not can_spawn():
            return False
        
        # Find empty cells
        empty_cells = []
        for row in range(GRID_SIZE):
            for col in range(GRID_SIZE):
                if grid[row][col] == 0:
                    empty_cells.append((row, col))
        
        if not empty_cells:
            return False
        
        # Place car in random empty cell
        row, col = random.choice(empty_cells)
        grid[row][col] = get_min_spawn_level()
        
        save_game()
        return True
    except Exception as e:
        print(f"Error in spawn_car: {e}")
        return False

def get_adjacent_cells(row, col):
    """Get adjacent cells (up, down, left, right)"""
    adjacent = []
    for dr, dc in [(0, 1), (0, -1), (1, 0), (-1, 0)]:
        new_row, new_col = row + dr, col + dc
        if 0 <= new_row < GRID_SIZE and 0 <= new_col < GRID_SIZE:
            adjacent.append((new_row, new_col))
    return adjacent

def merge_cars(row1, col1, row2, col2):
    """Merge two cars of same level"""
    global experience, message, message_timer
    
    level1 = grid[row1][col1]
    level2 = grid[row2][col2]
    
    # Check if levels are the same and not max level
    if level1 != level2 or level1 == 0 or level1 >= MAX_CAR_LEVEL:
        return False
    
    # Merge cars (no adjacency check needed)
    grid[row1][col1] = level1 + 1
    grid[row2][col2] = 0
    
    # Calculate experience based on level
    exp_gained = level1 * 5  # 1lvl=5xp, 2lvl=10xp, 3lvl=15xp, etc.
    experience += exp_gained
    update_profile_level()
    
    # Show message
    message = f"+{exp_gained} XP!"
    message_timer = 120  # Show for 2 seconds at 60 FPS
    
    save_game()
    return True

def format_time(seconds):
    """Format time as HH:MM:SS"""
    hours = int(seconds // 3600)
    minutes = int((seconds % 3600) // 60)
    secs = int(seconds % 60)
    return f"{hours:02d}:{minutes:02d}:{secs:02d}"

