def load_car_images():
    """Load and process car images from provided photos."""
    global car_images
    total_levels = MAX_CAR_LEVEL

    for level in range(1, MAX_CAR_LEVEL + 1):
        for event in pygame.event.get([pygame.QUIT]):
            if event.type == pygame.QUIT:
                pygame.quit()
                sys.exit()

        progress = ((level - 1) / total_levels) * 100
        draw_loading_screen(progress)
        asset_path = find_asset_by_token(IMAGE_TOKENS_BY_LEVEL[level - 1])
        try:
            if asset_path and asset_path.exists():
                loaded = pygame.image.load(str(asset_path)).convert_alpha()
                no_bg = remove_background(loaded)
                car_images[level] = pygame.transform.smoothscale(no_bg, (CELL_SIZE - 20, CELL_SIZE - 20))
            else:
                car_images[level] = create_fallback_car(level)
        except Exception:
            car_images[level] = create_fallback_car(level)
        draw_loading_screen((level / total_levels) * 100)

def get_level_progress(total_experience):
    """Return current profile level and progress to next level."""
    level = 1
    remaining = total_experience
    xp_to_next = BASE_XP_TO_LEVEL_UP

    while remaining >= xp_to_next:
        remaining -= xp_to_next
        level += 1
        xp_to_next = BASE_XP_TO_LEVEL_UP + (level - 1) * XP_STEP_PER_LEVEL

    return level, remaining, xp_to_next

