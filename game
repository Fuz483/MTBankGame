    draw_center_line_button("XP GOAL: +10 EVERY LEVEL", y_offset + 62, WHITE, (120, 130, 165), (36, 42, 58))
    
    # Premium message display with animation
    if message_timer > 0:
        # Message background with glow
        msg_surface = font_large.render(message, True, WHITE)
        msg_bg = pygame.Rect(0, 0, msg_surface.get_width() + 40, 50)
        msg_bg.center = (WIDTH // 2, HEIGHT - 60)
        
        # Message glow effect
        for i in range(3):
            glow_bg = pygame.Rect(msg_bg.x - i*2, msg_bg.y - i*2, 
                              msg_bg.width + i*4, msg_bg.height + i*4)
            glow_alpha = 80 - i * 25
            pygame.draw.rect(screen, (*ACCENT_COLOR[:3], glow_alpha), glow_bg, border_radius=15+i)
        
        pygame.draw.rect(screen, BLACK, msg_bg, border_radius=15)
        pygame.draw.rect(screen, ACCENT_COLOR, msg_bg, 3, border_radius=15)
        
        msg_rect = msg_surface.get_rect(center=msg_bg.center)
        screen.blit(msg_surface, msg_rect)
        message_timer -= 1
    
    return spawn_button

def handle_grid_click(pos, button):
    """Handle mouse click on grid"""
    global selected_car, experience, message, message_timer
    
    x, y = pos
    
    # Check if click is within grid
    if (x < GRID_OFFSET_X or x >= GRID_OFFSET_X + GRID_SIZE * CELL_SIZE or
        y < GRID_OFFSET_Y or y >= GRID_OFFSET_Y + GRID_SIZE * CELL_SIZE):
        return
    
    # Calculate grid position
    col = (x - GRID_OFFSET_X) // CELL_SIZE
    row = (y - GRID_OFFSET_Y) // CELL_SIZE
    
    # Check if cell has a car
    if grid[row][col] == 0:
        selected_car = None
        return
    
    # Right click to sell car
    if button == 3:  # Right click
        car_level = grid[row][col]
        merge_value = car_level * 5
        exp_gained = max(1, math.ceil(merge_value * 0.1))
        experience += exp_gained
        update_profile_level()
        grid[row][col] = 0
        selected_car = None
        
        message = f"SOLD! +{exp_gained} XP"
        message_timer = 120
        save_game()
        return
    
    # Left click for selection and merging
    if selected_car is None:
        # Select first car
        selected_car = (row, col)
    else:
        # Try to merge with selected car
        row1, col1 = selected_car
        if (row, col) == (row1, col1):
            # Deselect if clicking same car
            selected_car = None
        else:
            # Try to merge
            merge_cars(row1, col1, row, col)
            selected_car = None

def main():
    """Main game loop"""
    global message, message_timer, selected_car
    
    load_game()
    
    running = True
    spawn_button = Button(PANEL_OFFSET_X, GRID_OFFSET_Y + 50, 120, 40, "Spawn")
    
    while running:
        for event in pygame.event.get():
            if event.type == pygame.QUIT:
                running = False
            elif event.type == pygame.MOUSEBUTTONDOWN:
                if spawn_button.handle_event(event):
                    if not spawn_car():
                        message = "No empty cells!"
                        message_timer = 120
                else:
                    handle_grid_click(event.pos, event.button)
            else:
                spawn_button.handle_event(event)
        
        # Clean background without extra guide lines
        screen.fill((18, 20, 26))
        
        # Draw everything
        draw_grid()
        spawn_button = draw_ui()
        
        # Update display
        pygame.display.flip()
        clock.tick(60)
    
    pygame.quit()
    sys.exit()

if __name__ == "__main__":
    main()
